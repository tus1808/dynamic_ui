{
  "files.associations": {
    "*.h": "c"
  },
  "editor.quickSuggestions": {
    "other": true,
    "comments": false,
    "strings": false
  },
  "editor.suggestOnTriggerCharacters": true,
  "cSpell.enabledFileTypes": {
    "c": true,
    "cpp": true,
    "json": true,
    "markdown": true,
    "plaintext": true,
    "yaml": true
  },
  "cSpell.words": [
    "gboolean",
    "gchar",
    "gint",
    "guint",
    "gpointer",
    "gsize",
    "gssize",
    "gfloat",
    "gdouble",
    "xalign",
    "yalign",
    "halign",
    "valign",
    "hexpand",
    "vexpand",
    "pixbuf",
    "uart",
    "crtscts",
    "gstreamer"
  ],
  "cSpell.ignorePaths": [
    "build/**",
    "subprojects/**",
    "node_modules/**",
    "*.png",
    "*.jpg",
    "*.jpeg",
    "*.svg",
    "*.pdf",
    "*.drawio"
  ]
}